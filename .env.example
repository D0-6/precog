# Copy this to .env and fill in your values
# Get NVIDIA NIM key FREE at build.nvidia.com — no credit card needed

NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx

# Splunk (free trial at splunk.com)
SPLUNK_MCP_URL=https://your-splunk-instance:8089
SPLUNK_TOKEN=your-splunk-api-token

# GitHub (free at github.com/settings/tokens)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_ORG=your-github-org

# Jira (free at atlassian.com)
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_TOKEN=your-jira-api-token

# Slack (free bot at api.slack.com)
SLACK_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxx
SLACK_CHANNEL_IDS=C01234567,C09876543

# Set to true for demo — uses synthetic data, never fails
DEMO_MODE=true
